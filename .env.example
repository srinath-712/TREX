# TREX Environment Configuration
# Copy this file to .env and fill in your real API keys.

# LunarCrush API (Primary Social Data Source)
# Get your API key from https://lunarcrush.com/developers
LUNARCRUSH_API_KEY=your_lunarcrush_api_key_here

# Mock Mode Configuration
# Set to 'false' in production to use real APIs
USE_MOCKS=true
